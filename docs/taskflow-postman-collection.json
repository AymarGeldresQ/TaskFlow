      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/register",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "auth",
                "register"
              ]
            },
            "description": "Register new user. Copy accessToken and refreshToken from response into collection variables.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"alice@example.com\",\n  \"password\": \"SecurePass123!\",\n  \"fullName\": \"Alice Smith\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "_postman_id": "3f6f9a33-a7f2-4e51-a155-f3815da1228f",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if(pm.response.code===201){",
                  "  const b=pm.response.json();",
                  "  pm.collectionVariables.set('accessToken',b.accessToken);",
                  "  pm.collectionVariables.set('refreshToken',b.refreshToken);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "auth",
                "login"
              ]
            },
            "description": "Login and receive tokens.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"alice@example.com\",\n  \"password\": \"SecurePass123!\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "_postman_id": "79ac3806-7353-4fb6-a531-c8e832039604",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if(pm.response.code===200){",
                  "  const b=pm.response.json();",
                  "  pm.collectionVariables.set('accessToken',b.accessToken);",
                  "  pm.collectionVariables.set('refreshToken',b.refreshToken);",
                  "}"
                ]
              }
            }
          ]
        },
